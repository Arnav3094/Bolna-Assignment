# Redis connection URL
REDIS_URL=redis://localhost:6379

# RSS feed URL to monitor (default: OpenAI status page)
RSS_FEED_URL=https://status.openai.com/history.rss

# Polling interval in seconds (default: 30 - RSS is event-driven on provider side)
POLL_INTERVAL=30

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
